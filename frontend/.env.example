# API
VITE_API_URL=https://carbon-footprint-api-XXXX.us-central1.run.app

# Google Sign-In (PRIMARY — create in GCP Console → APIs & Services → Credentials → OAuth 2.0 Client ID → Web)
VITE_GOOGLE_CLIENT_ID=YOUR_CLIENT_ID.apps.googleusercontent.com

# Firebase Auth (OPTIONAL — after linking Firebase in console)
VITE_AUTH_ENABLED=true
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=agentflow-prod-assistant.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=agentflow-prod-assistant
VITE_FIREBASE_STORAGE_BUCKET=agentflow-prod-assistant.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
