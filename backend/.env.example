# Local Cloud Run / backend container environment variables

# Firebase service account JSON string OR use GOOGLE_APPLICATION_CREDENTIALS with a mounted key file.
FIREBASE_SERVICE_ACCOUNT=""
# GOOGLE_APPLICATION_CREDENTIALS="/tmp/service-account.json"

GCP_PROJECT_ID=your-gcp-project-id
GCP_REGION=us-central1
ALLOWED_ORIGINS=http://localhost:5173
ALLOW_GUEST_ACCESS=true
BQ_LOCATION=US
BQ_DATASET=ecotrack_analytics
REPORTS_BUCKET=your-project-carbon-reports
PUBSUB_TOPIC=carbon-events
GOOGLE_CLIENT_ID=your-google-client-id
LOG_LEVEL=debug
NODE_ENV=development
